---
const {
  title = "Heading",
  text = "Lorem ipsum dolor sit amet consectetur adipisicing elit. Facere, saepe.",
} = Astro.props;
---

<div class="section-heading">
  <h1>{title}</h1>
  <p>{text}</p>
</div>

<style>
  .section-heading {
    h1 {
      font-size: clamp(1.5rem, 1vw + 1rem, 1.75rem);
      margin-bottom: 0.25em;
      color: var(--primary-color);
    }

    p {
      font-size: 1rem;
      color: var(--gray-6);
      line-height: 1.5;
    }
  }
</style>

---
import "../styles/footer.css";
import githubIcon from "../assets/logos/bxl-github.svg?raw";
import linkedinIcon from "../assets/logos/bxl-linkedin.svg?raw";
import envelopeIcon from "../assets/logos/bx-envelope.svg?raw";
---

<!-- Footer -->
<footer>
  <div class="container">
    <!-- CTA -->
    <div class="footer-cta" id="contact">
      <div class="footer-cta-content">
        <p>I'd love to hear from you.</p>

        <span class="email">
          <a href="mailto:devhanza@gmail.com">devhanza@gmail.com</a>
          <i class="icon icon-copy"></i>
        </span>

        <p>Drop a message or connect below.</p>
      </div>
      <div class="footer-cta-links">
        <div class="footer-social">
          <a
            href="https://github.com/DevHanza/"
            aria-label="View Github profile"
          >
            <i set:html={githubIcon} aria-hidden="true" />
          </a>
          <a
            href="https://linkedin.com/in/devhanza/"
            aria-label="View Linkedin profile"
          >
            <i set:html={linkedinIcon} aria-hidden="true" />
          </a>
          <a href="mailto:devhanza@gmail.com" aria-label="Send an email.">
            <i set:html={envelopeIcon} aria-hidden="true" />
          </a>
        </div>
      </div>
    </div>

    <!--  Credits -->
    <div class="footer-credits">
      <p>Copyright © Hansana 2026. All Rights Reserved.</p>

      <div class="footer-social">
        <a href="https://github.com/DevHanza/" aria-label="View Github profile">
          <i set:html={githubIcon} aria-hidden="true" />
          <!-- 20px -->
        </a>
        <a
          href="https://linkedin.com/in/devhanza/"
          aria-label="View Linkedin profile"
        >
          <i set:html={linkedinIcon} aria-hidden="true" />
        </a>
        <a href="mailto:devhanza@gmail.com" aria-label="Send an email.">
          <i set:html={envelopeIcon} aria-hidden="true" />
        </a>
      </div>
    </div>
  </div>
</footer>

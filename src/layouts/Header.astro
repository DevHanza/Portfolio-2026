---
import "../styles/header.css";
---

<!-- Header -->
<header>
  <div class="header-title">
    <a href="/"> Hansana </a>
    <span>—— Software Engineer</span>
  </div>
  <nav class="nav-links">
    <div class="nav-links-social">
      <a href="https://github.com/DevHanza/" aria-label="View GitHub profile">
        <i class="bx bxl-github" aria-hidden="true"></i>
      </a>
      <a
        href="https://linkedin.com/in/devhanza/"
        aria-label="View Linkedin profile"
      >
        <i class="bx bxl-linkedin" aria-hidden="true"></i>
      </a>
    </div>

    <a href="#contact">
      <button class="btn btn-primary">
        Contact
        <div class="icon icon-arrow-up-right" aria-hidden="true"></div>
      </button>
    </a>
  </nav>
</header>
